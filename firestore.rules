rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getRole(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        ? get(/databases/$(database)/documents/users/$(uid)).data.role
        : 'anonymous';
    }
    function isOwner() { return request.auth != null && getRole(request.auth.uid) == 'owner'; }
    function isEditorOrOwner() {
      return request.auth != null && getRole(request.auth.uid) in ['owner', 'editor'];
    }

    // restaurants：閲覧は誰でも。追加・編集は編集者以上。削除はオーナーのみ。
    // （編集者は「削除」の代わりに deleteRequested / deleteRequestedBy / deleteRequestedAt を
    //   立てる＝更新なのでこのルールでOK。フィールド単位の制限はかけていません）
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create, update: if isEditorOrOwner();
      allow delete: if isOwner();
    }

    // users：役割(role)を管理。本人は自分のdisplayNameだけ変更可能。
    // roleの昇格（member→editor→owner）は、オーナーがFirebaseコンソールで直接書き換える運用。
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId
                     && request.resource.data.role == 'member';
      allow update: if request.auth != null && request.auth.uid == userId
                     && request.resource.data.role == resource.data.role;
    }

    // reviews：ログインしていれば誰でも投稿可（本人になりすまし防止のためauthorUidを検証）。
    // 削除・修正は本人か編集者以上のみ（不適切な投稿の削除用）。
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if request.auth != null &&
        (resource.data.authorUid == request.auth.uid || isEditorOrOwner());
    }

    // wishlist：行きたい店リスト。ログインしていれば誰でも閲覧・登録・感想投稿ができる。
    // 削除は「登録した本人」か「編集者以上」のみ。匿名表示はアプリ側（画面）で制御している。
    match /wishlist/{wishId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.addedBy == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null &&
        (resource.data.addedBy == request.auth.uid || isEditorOrOwner());
    }

    // contacts / groups：行ってみたい店を共有する相手（友達・グループ）。本人のものだけ読み書き可能。
    match /contacts/{contactId} {
      allow read, update, delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
    }
    match /groups/{groupId} {
      allow read, update, delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
    }

    // visited：ログインユーザーが「実際に行った」と記録した店舗（本人のものだけ読み書き可能）
    match /visited/{id} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // notifications：アプリ内通知。宛先本人だけが読み書き（既読化）できる。
    // 作成は「ログインしていれば誰でも他人宛てに作成可」（削除依頼・共有・感想・編集権限申請の通知に必要なため）
    match /notifications/{id} {
      allow read, update, delete: if request.auth != null && resource.data.recipientUid == request.auth.uid;
      allow create: if request.auth != null;
    }

    // roleRequests：編集権限の申請。本人とオーナーだけが読める。作成は本人のみ。
    match /roleRequests/{id} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null &&
        (resource.data.uid == request.auth.uid || isEditorOrOwner());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
